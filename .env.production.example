# Production environment for docker-compose.prod.yml.
# Copy to .env.production on the server and fill in real values.
# Never commit the populated file.

# Postgres (used by the postgres service AND substituted into DATABASE_URL).
POSTGRES_USER=cc_financial
POSTGRES_PASSWORD=
POSTGRES_DB=cc_financial

# Admin login
ADMIN_EMAIL=
# Generate with: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'your-password'
ADMIN_PASSWORD_HASH=

# Random 32+ byte secret. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Public URL + hostname
PUBLIC_HOSTNAME=financial.raumdock.org
PUBLIC_BASE_URL=https://financial.raumdock.org

# Random secret shared with OBS Browser Source URLs. Generate with: openssl rand -hex 32
PUBLIC_OVERLAY_TOKEN=

# Caddy ACME contact email (Let's Encrypt sends expiry notices here).
CADDY_ACME_EMAIL=

# Host port that the front-edge nginx forwards SNI traffic to.
# Must match the upstream port in the nginx stream map (default 3100).
CADDY_HOST_PORT=3100

# Twitch (Phase 3 — leave empty until then)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BROADCASTER_ID=
TWITCH_BROADCASTER_LOGIN=JustCallMeDeimos
TWITCH_EVENTSUB_SECRET=
TWITCH_REDIRECT_URI=https://financial.raumdock.org/api/twitch/oauth/callback
